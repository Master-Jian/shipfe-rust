{
  "name": "shipfe",
  "version": "2.1.0",
  "description": "A deployment tool for web applications",
  "main": "index.js",
  "bin": {
    "shipfe": "bin/shipfe"
  },
  "scripts": {
    "build": "cargo build --release && mkdir -p bin && cp target/release/shipfe bin/shipfe",
    "prepublishOnly": "npm run build",
    "test": "echo \"Error: no test specified\" && exit 1",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "keywords": [
    "deployment",
    "devops",
    "ssh",
    "ci-cd"
  ],
  "author": "Jans",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Master-Jian/shipfe-rust.git"
  },
  "license": "MIT",
  "files": [
    "bin/shipfe",
    "README.md"
  ],
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "cpu": [
    "x64",
    "arm64"
  ],
  "directories": {
    "doc": "docs"
  },
  "type": "module",
  "bugs": {
    "url": "https://github.com/Master-Jian/shipfe-rust/issues"
  },
  "homepage": "https://github.com/Master-Jian/shipfe-rust#readme",
  "devDependencies": {
    "vitepress": "^1.6.4"
  }
}
